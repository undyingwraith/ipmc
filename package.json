	"license": "MIT",
	"private": true,
	"type": "module",
	"packageManager": "yarn@4.10.3",
	"scripts": {
		"dev": "yarn workspaces foreach -Api run dev",
		"watch": "yarn workspaces foreach -Api --no-private --exclude ipmc-desktop run dev",
