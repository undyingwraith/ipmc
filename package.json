		"test": "yarn workspaces foreach -Apt run test",
		"cli": "yarn workspace ipmc-tools run cli"
	},
	"workspaces": [
		"packages/*"
	],
	"devDependencies": {
		"typescript": "^5.8.3"
	},
	"resolutions": {
		"blockstore-core@npm:^6.0.0": "patch:blockstore-core@npm%3A6.1.1#~/.yarn/patches/blockstore-core-npm-6.1.1-5c67813c75.patch",
